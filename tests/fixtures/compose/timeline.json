        "props": {},
        "expected": {
            "stateColors": "done=text-primary|current=text-base-content|upcoming=text-base-content/40|default=text-primary",
            "hrColors": "done=bg-primary|current=bg-base-content/30|upcoming=bg-base-content/15|default=bg-primary"
        }
    },
    {
        "name": "appearance=soft (opt-in) — done icon text-primary/70, hr bg-primary/30",
        "props": { "appearance": "soft" },
        "expected": {
            "stateColors": "done=text-primary/70|current=text-base-content|upcoming=text-base-content/40|default=text-primary/70",
            "hrColors": "done=bg-primary/30|current=bg-base-content/30|upcoming=bg-base-content/15|default=bg-primary/30"
